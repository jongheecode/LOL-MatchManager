# developer.riotgames.com 에서 발급받은 API 키 (Personal key는 24시간마다 재발급 필요)
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 기본 플랫폼 라우팅 (kr, na1, euw1, jp1 ...)
DEFAULT_PLATFORM=kr

# 기본 리전 라우팅 (asia, americas, europe) - platform 에 맞춰 자동 매핑되지만 override 가능
DEFAULT_REGIONAL=asia

PORT=8787

# --- AI(Gemini) 모드 ---
# ai.google.dev 에서 발급받은 Gemini API 키. 없으면 /api/ai/* 가 503으로 응답
GEMINI_API_KEY=
# 사용할 모델 (공식 stable). 배포 시 AI Studio에서 무료 접근/실 RPM·TPM·RPD 확인 후 조정
GEMINI_MODEL=gemini-3.5-flash
# 전역 일일 Gemini 호출 상한(rolling 24h). 프로젝트 실제 RPD의 60~70% 이하 권장
AI_GLOBAL_DAILY_LIMIT=50
# IP당 분당 AI 요청 상한
AI_IP_LIMIT_PER_MINUTE=2
# Google로 동시에 나가는 요청 수
AI_MAX_CONCURRENT=2
# 운영 CORS 허용 origin (비우면 전체 허용 - 개발/동일 origin 배포용)
APP_ORIGIN=https://matchmanager.onrender.com
